# New Nomads Academy төслийн жишиг орчны файл
#
# Энэ файлыг .env.local болгон хуулж аваад өөрийн бодит утгуудыг бөглөнө.
# Бодит нууц мэдээллийг GitHub-д commit хийхгүй.

# Cal.com booking хэсэгт ашиглах link.
# Жишээ: https://cal.com/newnomads
NEXT_PUBLIC_CAL_LINK=""

# byl.mn API-ийн үндсэн хаяг.
# Invoice болон callback хүсэлтүүдийг серверээс энэ хаяг руу явуулна.
# Жишээ: https://byl.mn/api
BYL_API_BASE_URL="https://byl.mn/api"

# byl.mn dashboard дээр харагддаг таны төслийн ID.
# Энэ байхгүй бол payment урсгал mock fallback ашиглана.
BYL_PROJECT_ID=""

# Төлбөрийн горим.
# test -> хөгжүүлэлтийн аюулгүй горим
# live -> бодит production горим
BYL_MODE="test"

# byl.mn API token.
# Server-side invoice үүсгэхэд ашиглагдана.
# Үүнийг byl.mn dashboard дээрээс авна.
BYL_API_TOKEN=""

# Callback/webhook ирэхэд signature шалгах secret.
# Live орчинд хэрэгтэй байж болно, test орчинд хоосон үлдээж болно.
BYL_WEBHOOK_SECRET=""
